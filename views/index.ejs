<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title data-i18n="page.title">AutoTrade | Find Your Dream Car</title>
  <meta name="description" content="AutoTrade — Browse thousands of premium cars in Egypt. SUV, Sedan, Hatchback. Sell your car quickly.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/cars.css">
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="/css/messaging.css">
  <script src="/js/data.js" defer></script>
  <script src="/js/auth.js" defer></script>
  <script src="/js/i18n.js" defer></script>
  <script src="/js/settings.js" defer></script>
  <script src="/js/theme.js" defer></script>
  <script src="/js/messaging.js" defer></script>
  <script src="/js/bidding.js" defer></script>
  <script src="/js/main.js" defer></script>
</head>
<body>

  <!-- Navigation -->
  <header id="main-header">
    <div class="container nav-container">
      <a href="/" class="logo" id="logo">Auto<span>Trade</span></a>
      <button class="menu-toggle" id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">☰</button>
      <nav class="nav-links" id="nav-links">
           <a href="/" class="active" data-i18n="nav.home">Home</a>
        <a href="/categories?type=all" data-i18n="nav.browse">Browse Cars</a>
        <a href="/favorites" data-i18n="nav.favorites">Favorites</a>
        <a href="/sell" class="nav-sell-btn" data-i18n="nav.sell">Sell My Car</a>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <img src="https://images.unsplash.com/photo-1544636331-e26879cd4d9b?auto=format&fit=crop&w=1920&q=85" alt="Premium sports car">
    </div>
    <div class="container">
 <div class="hero-badge" data-i18n="hero.badge">Egypt's #1 Car Marketplace</div>
      <h1><span style="color: inherit;" data-i18n="hero.title.part1">Find your</span> <span data-i18n="hero.title.part2">dream car.</span><br>Trade with confidence.</h1>
      <p data-i18n="hero.subtitle">Browse thousands of verified cars from trusted sellers across Egypt. Transparent pricing, real photos.</p>
      <div class="hero-actions">
               <a href="/categories?type=all" class="btn btn-primary btn-lg" id="hero-browse-btn" data-i18n="hero.btn.browse">Browse Inventory</a>
        <a href="/sell" class="btn btn-outline btn-lg" id="hero-sell-btn" data-i18n="hero.btn.sell">Sell Your Car</a>
      </div>
    </div>
  </section>

  <!-- Shop by Category -->
  <section style="background:var(--color-bg-alt); border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
    <div class="container">
      <div style="margin-bottom:2.5rem; text-align:center;">
        <span class="section-label" data-i18n="cat.section.label">Browse by Type</span>
        <h2 class="section-title" data-i18n="cat.section.title">Select a Category</h2>
        <p class="section-subtitle" data-i18n="cat.section.subtitle">Find exactly what you are looking for</p>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.25rem;">

        <a href="/categories?type=suv" class="cat-card" id="cat-suv">
          <img src="https://images.unsplash.com/photo-1533473359331-0135ef1b58bf?auto=format&fit=crop&w=800&q=80" alt="SUVs">
          <div class="cat-card-overlay">
            <div>
              <h3 data-i18n="cat.suv.title">SUV</h3>
              <span data-i18n="cat.suv.desc">Spacious & Powerful</span>
            </div>
          </div>
        </a>

        <a href="/categories?type=sedan" class="cat-card" id="cat-sedan">
          <img src="https://images.unsplash.com/photo-1555215695-3004980ad54e?auto=format&fit=crop&w=800&q=80" alt="Sedans">
          <div class="cat-card-overlay">
            <div>
              <h3 data-i18n="cat.sedan.title">Sedan</h3>
              <span data-i18n="cat.sedan.desc">Elegant & Comfortable</span>
            </div>
          </div>
        </a>

        <a href="/categories?type=hatchback" class="cat-card" id="cat-hatchback">
          <img src="https://images.unsplash.com/photo-1541899481282-d53bffe3c35d?auto=format&fit=crop&w=800&q=80" alt="Hatchbacks">
          <div class="cat-card-overlay">
            <div>
              <h3 data-i18n="cat.hatch.title">Hatchback</h3>
              <span data-i18n="cat.hatch.desc">Practical & Economical</span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Latest Arrivals -->
  <section style="background:var(--color-bg);">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-label" data-i18n="feat.section.label">Latest Listings</span>
          <h2 class="section-title" style="margin-bottom:0;" data-i18n="feat.section.title">New Arrivals</h2>
        </div>
        <a href="/categories?type=all" class="btn btn-outline" id="view-all-btn" data-i18n="feat.btn.viewall">View All →</a>
      </div>
      <div class="grid" id="latest-cars-grid">
        <!-- Injected by main.js -->
      </div>
    </div>
  </section>

  <!-- Why AutoTrade -->
  <section class="features-section">
    <div class="container">
      <div style="margin-bottom:2.5rem; text-align:center;">
        <span class="section-label" data-i18n="features.section.label">Why AutoTrade</span>
        <h2 class="section-title" data-i18n="features.section.title">Built for serious car buyers</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:1.25rem;">
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 data-i18n="features.card1.title">Verified Listings</h3>
          <p data-i18n="features.card1.desc">Every listing is reviewed before being published on our platform.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 data-i18n="features.card3.title">Internal Messaging</h3>
          <p data-i18n="features.card3.desc">Message sellers directly through our secure platform — no external apps needed.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 data-i18n="features.card2.title">Publish in Minutes</h3>
          <p data-i18n="features.card2.desc">Sell your car quickly using our 2-minute easy listing form.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3 data-i18n="features.card4.title">Save Favorites</h3>
          <p data-i18n="features.card4.desc">Save the cars you like and return to them anytime.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="logo">Auto<span>Trade</span></span>
          <p data-i18n="footer.desc">Your trusted platform to buy and sell premium cars in Egypt. Transparent pricing, real photos.</p>
        </div>
        <div class="footer-col">
          <h4 data-i18n="cat.section.label">Browse</h4>
          <ul>
            <li><a href="/categories?type=all" data-i18n="browse.filter.all">All Cars</a></li>
            <li><a href="/categories?type=suv" data-i18n="browse.filter.suv">SUV</a></li>
            <li><a href="/categories?type=sedan" data-i18n="browse.filter.sedan">Sedan</a></li>
            <li><a href="/categories?type=hatchback" data-i18n="browse.filter.hatch">Hatchback</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 data-i18n="settings.account">Account</h4>
          <ul>
            <li><a href="/sell" data-i18n="nav.sell">Sell My Car</a></li>
            <li><a href="/favorites" data-i18n="nav.favorites">My Favorites</a></li>
            <li><a href="/messaging" data-i18n="msg.title">Messages</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p data-i18n="footer.rights">© 2026 AutoTrade. All rights reserved.</p>
        <div class="footer-links">
          <a href="#" data-i18n="footer.privacy">Privacy Policy</a>
          <a href="#" data-i18n="footer.terms">Terms of Use</a>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>
