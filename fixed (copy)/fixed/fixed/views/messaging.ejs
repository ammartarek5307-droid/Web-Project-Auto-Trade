<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Messages | AutoTrade</title>
  <meta name="description" content="Your messages and conversations on AutoTrade.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="/css/messaging.css">
  <script src="/js/data.js" defer></script>
  <script src="/js/auth.js" defer></script>
  <script src="/js/i18n.js" defer></script>
  <script src="/js/settings.js" defer></script>
  <script src="/js/theme.js" defer></script>
  <script src="/js/messaging.js" defer></script>
  <script src="/js/main.js" defer></script>
</head>
<body>
  <header style="position:sticky;">
    <div class="container nav-container">
      <a href="/" class="logo">Auto<span>Trade</span></a>
      <button class="menu-toggle" id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">☰</button>
      <nav class="nav-links" id="nav-links">
        <a href="/">Home</a>
        <a href="/categories?type=all">Browse Cars</a>
        <a href="/favorites">Favorites</a>
        <a href="/sell" class="nav-sell-btn">Sell My Car</a>
      </nav>
      <a href="/admin-login" class="admin-access-btn" title="Admin Panel">
        <span>⚙</span><span>Admin</span>
      </a>
    </div>
  </header>
  <div class="page-hero" style="margin-top:0;">
    <div class="container">
      <h1>Messages</h1>
      <p>Your conversations with buyers and sellers</p>
    </div>
  </div>
  <main class="container" style="padding-top:2rem; padding-bottom:4rem;">
    <div id="messaging-container">
      <div style="text-align:center; padding:3rem; color:var(--text-muted);">Loading messages...</div>
    </div>
  </main>
  <footer>
    <div class="container">
      <div class="footer-bottom" style="border:none; padding:0;">
        <p>© 2026 AutoTrade. All rights reserved.</p>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/categories?type=all">Browse</a>
        </div>
      </div>
    </div>
  </footer>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      if (typeof initTheme === 'function') initTheme();
      if (typeof initAuthGate === 'function') initAuthGate();
      if (typeof initMobileMenu === 'function') initMobileMenu();
      // Give auth.js and data.js time to initialize before loading the messaging UI
      setTimeout(() => {
        if (typeof initMessagingPage === 'function') {
          initMessagingPage();
        }
      }, 300);
    });
  </script>
</body>
</html>
