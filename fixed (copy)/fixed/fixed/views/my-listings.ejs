<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Listings | AutoTrade</title>
  <meta name="description" content="View your listed cars on AutoTrade.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/cars.css">
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="/css/messaging.css">
  <script src="/js/data.js" defer></script>
  <script src="/js/auth.js" defer></script>
  <script src="/js/i18n.js" defer></script>
  <script src="/js/settings.js" defer></script>
  <script src="/js/theme.js" defer></script>
  <script src="/js/messaging.js" defer></script>
  <script src="/js/bidding.js" defer></script>
  <script src="/js/main.js" defer></script>
  <script src="/js/cars.js" defer></script>
</head>
<body>
  <header style="position:sticky;">
    <div class="container nav-container">
      <a href="/" class="logo">Auto<span>Trade</span></a>
      <button class="menu-toggle" id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">☰</button>
      <nav class="nav-links" id="nav-links">
        <a href="/">Home</a>
        <a href="/categories?type=all">Browse Cars</a>
        <a href="/favorites">Favorites</a>
        <a href="/sell" class="nav-sell-btn">Sell My Car</a>
      </nav>
      <a href="/admin-login" class="admin-access-btn" title="Admin Panel">
        <span>⚙</span><span>Admin</span>
      </a>
    </div>
  </header>
  <div class="page-hero" style="margin-top:0;">
    <div class="container">
      <h1>My Listings</h1>
      <p id="my-listings-count">Loading...</p>
    </div>
  </div>
  <main class="container favorites-layout">
    <div id="my-listings-empty" style="display:none;">
      <div class="empty-state">
        <div class="empty-state-icon">Empty</div>
        <h3>You haven't listed any cars yet</h3>
        <p>List your car to reach thousands of buyers.</p>
        <a href="/sell" class="btn btn-primary btn-lg" id="go-sell-btn">Sell My Car</a>
      </div>
    </div>
    <div class="grid" id="my-listings-grid">
      <!-- Injected by script -->
    </div>
  </main>
  <footer>
    <div class="container">
      <div class="footer-bottom" style="border:none; padding:0;">
        <p>© 2026 AutoTrade. All rights reserved.</p>
        <div class="footer-links">
          <a href="/categories?type=all">Browse All Cars</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      const grid = document.getElementById('my-listings-grid');
      const emptyState = document.getElementById('my-listings-empty');
      const countEl = document.getElementById('my-listings-count');

      const token = localStorage.getItem('at_jwt');
      if (!token) {
        window.location.href = '/';
        return;
      }

      try {
        const res = await fetch('/api/cars/my-listings', {
          headers: { 'Authorization': 'Bearer ' + token }
        });
        const data = await res.json();
        
        if (data.success) {
          const cars = data.cars;
          if (countEl) countEl.textContent = `${cars.length} listed cars`;

          if (cars.length === 0) {
            grid.style.display = 'none';
            emptyState.style.display = 'block';
          } else {
            // Render the cards using createCarCard globally available in main.js
            grid.innerHTML = cars.map(car => window.createCarCard(car)).join('');
            
            // Replace the card actions with a Delete button
            grid.querySelectorAll('.card').forEach(card => {
              const carId = card.getAttribute('data-car-id');
              const actions = card.querySelector('.card-actions');
              if (actions) {
                actions.innerHTML = `
                  <a href="/car-details?id=${carId}" class="btn btn-primary btn-sm" style="flex: 1; text-align: center;">View Details</a>
                  <button class="btn btn-danger btn-sm delete-listing-btn" data-id="${carId}" style="flex: 1;">Delete Listing</button>
                `;
              }
            });

            // Bind delete events
            grid.querySelectorAll('.delete-listing-btn').forEach(btn => {
              btn.addEventListener('click', async (e) => {
                e.preventDefault();
                e.stopPropagation();
                if (!confirm('Are you sure you want to delete this listing?')) return;
                
                const id = btn.getAttribute('data-id');
                try {
                  const delRes = await fetch(`/api/cars/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + token }
                  });
                  const delData = await delRes.json();
                  if (delData.success) {
                    btn.closest('.card').remove();
                    const remaining = grid.querySelectorAll('.card').length;
                    if (countEl) countEl.textContent = `${remaining} listed cars`;
                    if (remaining === 0) {
                      grid.style.display = 'none';
                      emptyState.style.display = 'block';
                    }
                    if (window.showToast) window.showToast('Listing deleted successfully', 'success');
                  } else {
                    if (window.showToast) window.showToast(delData.error || 'Failed to delete listing', 'error');
                  }
                } catch (err) {
                  console.error(err);
                  if (window.showToast) window.showToast('Failed to delete listing', 'error');
                }
              });
            });
          }
        } else {
          if (countEl) countEl.textContent = 'Error loading listings';
        }
      } catch (err) {
        console.error(err);
        if (countEl) countEl.textContent = 'Error loading listings';
      }
    });
  </script>
</body>
</html>
