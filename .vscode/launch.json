    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:3000",
            "preLaunchTask": "Run backend server",
            "serverReadyAction": {
                "pattern": "(https?://localhost:3000|http://127\\.0\\.0\\.1:3000)",
                "uri": "http://localhost:3000",
                "action": "openExternally"
            },
            "webRoot": "${workspaceFolder}/fixed (delete ad)/fixed/fixed/public"
        }
    ]
}